{
    "name": "sofyco/facebook-security-voter-bundle",
    "type": "symfony-bundle",
    "version": "1.0.0",
    "description": "Symfony Facebook Security Voter Bundle",
    "keywords": ["php", "symfony", "facebook", "security", "voter", "bundle"],
    "homepage": "https://github.com/sofyco/facebook-security-voter-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Sofiia Korzhova",
            "email": "sofykorzhova@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "symfony/framework-bundle": "^8.0",
        "symfony/security-bundle": "^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.1",
        "symfony/browser-kit": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Sofyco\\Bundle\\FacebookSecurityVoterBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sofyco\\Bundle\\FacebookSecurityVoterBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    }
}
